    "/user-management": {
      "summary": "",
      "description": "",
      "parameters": [],
      "get": {
        "operationId": "getUserManagementForm",
        "summary": "User Management Form",
        "description": "Returns a form for user management (password change)",
        "tags": [],
        "parameters": [],
        "requestBody": {},
        "responses": {
          "401": {
            "description": "Unauthorized",
            "headers": {
              "WWW-Authenticate": {
                "schema": {
                  "type": "string"
                },
                "description": "Basic authentication challenge"
              }
            }
          },
          "200": {
            "description": "User management form",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ],
        "deprecated": false
      },
      "post": {
        "operationId": "updateUser",
        "summary": "Update User",
        "description": "Updates user information (currently only password changes)",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": {
                    "type": "string",
                    "format": "password",
                    "description": "User's new password"
                  },
                  "username": {
                    "type": "string",
                    "description": "User's username"
                  },
                  "confirm_password": {
                    "type": "string",
                    "format": "password",
                    "description": "Confirmation of new password"
                  }
                },
                "required": [
                  "username",
                  "password",
                  "confirm_password"
                ]
              }
            }
          }
        },
        "responses": {
          "404": {
            "description": "User not found",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "headers": {
              "WWW-Authenticate": {
                "schema": {
                  "type": "string"
                },
                "description": "Basic authentication challenge"
              }
            }
          },
          "200": {
            "description": "User information successfully updated",
            "content": {
              "text/html": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "security": [
          {
            "basicAuth": []
          }
        ],
        "deprecated": false
      }
    }
