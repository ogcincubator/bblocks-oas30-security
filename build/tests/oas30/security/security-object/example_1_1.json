  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "required": [
          "type",
          "title",
          "status"
        ],
        "properties": {
          "detail": {
            "type": "string",
            "description": "A human-readable explanation specific to this occurrence of the problem"
          },
          "type": {
            "type": "string",
            "format": "uri",
            "description": "A URI reference that identifies the problem type"
          },
          "title": {
            "type": "string",
            "description": "A short, human-readable summary of the problem type"
          },
          "status": {
            "type": "integer",
            "description": "The HTTP status code"
          }
        }
      },
      "UserManagementOperation": {
        "type": "object",
        "required": [
          "operation"
        ],
        "properties": {
          "fullName": {
            "type": "string",
            "description": "The full name of the user (for create/update operations)"
          },
          "api_id": {
            "type": "string",
            "description": "The API ID for grant/revoke operations"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "The password for the user (for create/update operations)"
          },
          "operation": {
            "type": "string",
            "description": "The operation to perform",
            "enum": [
              "create",
              "update",
              "delete",
              "grant",
              "revoke"
            ]
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "The email address for the user (for create/update operations)"
          },
          "username": {
            "type": "string",
            "description": "The username of the target user"
          }
        }
      },
      "UserRegistration": {
        "type": "object",
        "required": [
          "username",
          "password",
          "email"
        ],
        "properties": {
          "fullName": {
            "type": "string",
            "description": "The full name of the user"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "The password for the new user"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "The email address for the new user"
          },
          "username": {
            "type": "string",
            "description": "The username for the new user"
          }
        }
      }
    },
